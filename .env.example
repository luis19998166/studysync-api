PORT=3000
NODE_ENV=development

# Redis — crear cuenta gratuita en https://upstash.com
# Dashboard → Redis → Create Database → copiar "REDIS_URL"
REDIS_URL=rediss://default:TU_TOKEN@tu-host.upstash.io:6379

# Supabase — crear proyecto en https://supabase.com
# Settings → Database → Connection string → Transaction pooler (6543)
DATABASE_URL=postgresql://postgres.TU_PROYECTO:TU_PASSWORD@aws-X-region.pooler.supabase.com:6543/postgres
# Settings → Database → Connection string → Session mode (5432)
DIRECT_URL=postgresql://postgres.TU_PROYECTO:TU_PASSWORD@aws-X-region.pooler.supabase.com:5432/postgres

# JWT — cambiar por una cadena aleatoria larga en produccion
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_segura_minimo_32_chars
JWT_EXPIRES_IN=1h
